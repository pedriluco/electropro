# ============================================================
# ELECTRO-LAB DIGITAL — Variables de entorno
# Copia este archivo como .env y llena los valores
# NUNCA subas .env a git (ya está en .gitignore)
# ============================================================

# Puerto del servidor (por defecto 3000)
PORT=3000

# ── BASE DE DATOS ────────────────────────────────────────────
# Descomenta el bloque que uses y borra los demás

# MySQL / MariaDB
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=tu_password
# DB_NAME=electro_lab

# PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=tu_password
# DB_NAME=electro_lab

# MongoDB
# MONGO_URI=mongodb://localhost:27017/electro_lab

# SQLite (no necesita variables, solo el path en db/database.js)

# ── UPLOADS ──────────────────────────────────────────────────
# Carpeta donde se guardan los archivos subidos
UPLOADS_DIR=uploads

# ── SEGURIDAD ────────────────────────────────────────────────
# Cambia este valor por una cadena larga y aleatoria
JWT_SECRET=cambia_esto_por_algo_seguro_generado_al_azar
